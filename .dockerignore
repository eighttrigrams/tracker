# Build artefacts (regenerated inside the image)
target/
node_modules/
.shadow-cljs/
.cpcache/
resources/public/js/

# Local data & state
data/
*.db
logs/
.backups/
nohup.out
hooks.log

# Local & dev config. config.edn is gitignored and user-local; the
# canonical defaults live in config.edn.template (allowlisted below,
# COPYed as config.edn by Dockerfile.e2e). config.prod.edn is COPYed
# by the production Dockerfile.
.env
config.edn
config.edn.*
!config.edn.template
!config.prod.edn
.credentials
.editor-layouts.json
.lsp/
.clj-kondo/
.claude/

# REPL & process state
.nrepl-port
.server.port
.shadow-cljs.pid

# Test outputs (test/ itself is COPYed by Dockerfile.e2e — it contains
# the e2e features/steps, playwright.config.ts, and e2e_config.edn).
test-resources/
test-results/
playwright-report/
.playwright-mcp/

# Generated / scratch
build-next-feature/
.features-gen/
specs/

# Docs, screenshots, ops scripts
docs/
scripts/
*.md
*.png

# OS / VCS / tooling
.git/
.gitignore
.dockerignore
.DS_Store
.vscode/
.idea/

# Project tooling not needed for image builds
Makefile
bb.edn
fly.toml
