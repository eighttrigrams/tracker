{:paths ["src/clj" "src/cljc" "resources"]
 :deps {org.clojure/clojure {:mvn/version "1.12.5"}
        org.clojure/data.json {:mvn/version "2.5.2"}
        com.github.seancorfield/next.jdbc {:mvn/version "1.3.1118"}
        com.github.seancorfield/honeysql {:mvn/version "2.7.1389"}
        org.xerial/sqlite-jdbc {:mvn/version "3.53.2.0"}
        dev.weavejester/ragtime.next-jdbc {:mvn/version "0.12.1"}
        ring/ring-core {:mvn/version "1.15.4"}
        ring/ring-json {:mvn/version "0.5.1"}
        info.sunng/ring-jetty9-adapter {:mvn/version "0.38.0"}
        ring-cors/ring-cors {:mvn/version "0.1.13"}
        compojure/compojure {:mvn/version "1.7.2"}
        buddy/buddy {:mvn/version "2.0.0"}
        nrepl/nrepl {:mvn/version "1.7.0"}
        com.taoensso/telemere {:mvn/version "1.2.1"}
        clj-http/clj-http {:mvn/version "3.13.1"}
        org.jsoup/jsoup {:mvn/version "1.22.2"}
        aero/aero {:mvn/version "1.1.6"}}
 :aliases {:run {:exec-fn et.tr.server/-main}
           :test {:extra-paths ["test/unit" "test/integration"]
                  :extra-deps {io.github.cognitect-labs/test-runner {:git/tag "v0.5.1"
                                                                     :git/sha "dfb30dd6605cb6c0efc275e1df1736f6e90d4d73"}
                               ring/ring-mock {:mvn/version "0.6.2"}}
                  :main-opts ["-m" "cognitect.test-runner"
                              "-d" "test/unit"
                              "-d" "test/integration"]
                  :exec-fn cognitect.test-runner.api/test
                  :exec-args {:dirs ["test/unit" "test/integration"]}}
           :build {:deps {io.github.clojure/tools.build {:git/tag "v0.10.14" :git/sha "1176afd38dc39cb1880bd990d85718d4a61e194d"}}
                   :ns-default build}}}
